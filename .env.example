# ─── Django ────────────────────────────────────────────────
SECRET_KEY=genera-una-clave-con-get_random_secret_key
DEBUG=False
BASE_URL=https://elroperitotienda.com.ar
ALLOWED_HOSTS=elroperitotienda.com.ar,www.elroperitotienda.com.ar

# ─── Base de datos ─────────────────────────────────────────
# Railway provee DATABASE_URL automáticamente.
# Si existe DATABASE_URL, se usa. Si no, se usan los campos individuales.
DATABASE_URL=
DB_NAME=elroperito
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ─── CORS / CSRF ──────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://elroperitotienda.com.ar,https://www.elroperitotienda.com.ar
CSRF_TRUSTED_ORIGINS=https://elroperitotienda.com.ar,https://www.elroperitotienda.com.ar

# ─── Mercado Pago ─────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_WEBHOOK_URL=https://elroperitotienda.com.ar/webhook
MP_WEBHOOK_SECRET=

# ─── Email SMTP (Gmail) ───────────────────────────────────
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ─── Cloudinary (imágenes en la nube) ──────────────────────
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# ─── Otros ─────────────────────────────────────────────────
FRONTEND_URL=https://elroperitotienda.com.ar
SHIPPING_COST=0
